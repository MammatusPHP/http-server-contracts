{
  "name": "mammatus/http-server-contracts",
  "description": "HTTP Server contracts",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "psr/http-message": "^1.1 || ^2.0",
    "psr/http-server-middleware": "^1.0.2"
  },
  "require-dev": {
    "wyrihaximus/makefiles": "^0.12.0",
    "wyrihaximus/test-utilities": "^13.2.0"
  },
  "autoload": {
    "psr-4": {
      "Mammatus\\Http\\Server\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "ergebnis/composer-normalize": true,
      "infection/extension-installer": true,
      "phpstan/extension-installer": true,
      "wyrihaximus/makefiles": true,
      "wyrihaximus/test-utilities": true
    },
    "platform": {
      "php": "8.4.13"
    },
    "sort-packages": true
  },
  "extra": {
    "wyrihaximus": {
      "supported-features": {
        "unit-tests": false
      }
    }
  },
  "scripts": {
    "post-install-cmd": [
      "make on-install-or-update || true"
    ],
    "post-update-cmd": [
      "make on-install-or-update || true"
    ]
  }
}
